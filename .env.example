# Decoy Library — Environment Configuration
# Copy to .env and adjust paths for your system.
# On Windows, use forward slashes or escaped backslashes.

# ── General ──────────────────────────────────────────────────────────────
PYTHONUTF8=1
DECOY_TOOLS_DIR=~/tools

# ── tFold (TCR-pMHC structure prediction) ────────────────────────────────
# Git repo: https://github.com/TencentAI4S/tfold.git
TFOLD_DIR=~/tools/tfold
TFOLD_WEIGHTS_DIR=~/tools/tfold/weights
# Optional: inference server URL (if deployed)
# TFOLD_SERVER_URL=http://localhost:8501

# ── AlphaFold3 (high-accuracy structure refinement) ──────────────────────
# Git repo: https://github.com/google-deepmind/alphafold3.git
AF3_DIR=~/tools/alphafold3
AF3_MODEL_DIR=~/tools/alphafold3/models
AF3_DB_DIR=~/tools/alphafold3/databases
AF3_USE_DOCKER=false
AF3_DOCKER_IMAGE=alphafold3
# AF3_GPU_DEVICE=all

# ── ProteinMPNN (inverse sequence design) ────────────────────────────────
# Git repo: https://github.com/dauparas/ProteinMPNN.git
PROTEINMPNN_DIR=~/tools/ProteinMPNN

# ── NetMHCpan (optional, academic license required) ──────────────────────
# NETMHCPAN_CMD=netMHCpan
# NETMHCPAN_DIR=~/tools/netMHCpan-4.1

# ── GitHub proxy (for China mainland) ────────────────────────────────────
# GITHUB_PROXY=https://ghfast.top/
